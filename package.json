{
  "name": "aicoin-lark-webhook",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run dev:vercel",
    "dev:vercel": "npx --yes vercel@54.9.0 dev",
    "build": "tsc --noEmit",
